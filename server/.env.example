# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # set to "production" in prod

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/serveease
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/serveease

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173
# Multiple origins example:
# CLIENT_URL=http://localhost:5173,https://serveease.example.com
